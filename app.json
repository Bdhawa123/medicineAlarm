{
  "expo": {
    "name": "medicineAlarm",
    "slug": "medicineAlarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "SCHEDULE_EXACT_ALARM"
      ],
      "package": "com.anonymous.medicationsalarm",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Access for medicine scanning",
          "enableCodeScanner": true
        }
      ]
    ]
  }
}